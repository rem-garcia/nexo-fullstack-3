{
    "compilerOptions": {
        "rootDir": ".",
        "outDir": "./dist",
        "module": "ESNext",
        "jsx": "react-jsx",
        "moduleResolution": "bundler",
        "target": "ES2017",
        "lib": ["ES2017"],
        "sourceMap": true,
        "declaration": true,
        "declarationMap": true,
        "strict": true,
        "skipLibCheck": true,
        "esModuleInterop": true
    },
    "include": ["**/*.ts", "**/*.tsx"]
}
